rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidIntern(data) {
      return data.studentId is string && data.studentId.size() > 0
          && data.firstName is string && data.firstName.size() > 0 && data.firstName.size() <= 100
          && data.lastName is string && data.lastName.size() > 0 && data.lastName.size() <= 100
          && data.level is string && data.level.size() > 0
          && data.major is string && data.major.size() > 0
          && (data.university is string)
          && (data.department is list)
          && (data.startDate is string)
          && (data.endDate is string)
          && data.status in ['รอฝึกงาน', 'กำลังฝึกงาน', 'ฝึกงานสำเร็จ']
          && (request.method == 'create' ? data.createdAt == request.time : true)
          && data.updatedAt == request.time;
    }

    function isValidAttendance(data) {
      return data.internId is string && isValidId(data.internId)
          && data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
          && data.status in ['present', 'late', 'sick', 'personal', 'absent'];
    }

    function isValidEvaluation(data) {
      return data.internId is string && isValidId(data.internId)
          && data.totalScore is number
          && data.scores is map;
    }

    function isValidActivity(data) {
      return data.internId is string && isValidId(data.internId)
          && data.title is string && data.title.size() > 0;
    }

    // --- Collection Rules ---

    match /interns/{internId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidIntern(incoming());
      allow update: if isSignedIn() && isValidIntern(incoming());
      allow delete: if isSignedIn();
    }

    match /attendance/{attendanceId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidAttendance(incoming());
      allow update: if isSignedIn() && isValidAttendance(incoming());
      allow delete: if isSignedIn();
    }

    match /evaluations/{evaluationId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidEvaluation(incoming());
      allow update: if isSignedIn() && isValidEvaluation(incoming());
      allow delete: if isSignedIn();
    }

    match /activities/{activityId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidActivity(incoming());
      allow update: if isSignedIn() && isValidActivity(incoming());
      allow delete: if isSignedIn();
    }
  }
}
